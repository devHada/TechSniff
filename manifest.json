{
  "manifest_version": 3,
  "name": "TechDetector",
  "version": "1.0.0",
  "description": "Detect the tech stack of any website instantly.",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
